# ==============================================================
#  .dockerignore — files NOT copied into the Docker image
# ==============================================================
#  Keeps the Docker image small and fast to build.

# Dataset (very large — not needed at runtime)
dataset/

# Python cache
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# Training artifacts (not needed in production)
training_history.json
training_curves.png
confusion_matrix.png
gradcam_results.png
sample_images.png
class_distribution.png

# Development files
*.ipynb
.git/
.gitignore
README.md
evaluate.py
train.py